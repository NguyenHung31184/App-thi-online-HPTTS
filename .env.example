# App Thi Online — env
# Copy sang .env và điền giá trị thật

# Supabase (cùng project với TTDT hoặc project riêng)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 1 = COCO-SSD (điện thoại/sách/laptop) + BlazeFace. 0 = chỉ BlazeFace (mặt / nhiều người), không phát hiện vật lạ
VITE_AI_PROCTORING_ENABLED=0

# OCR CCCD — OCR proxy service độc lập (deploy riêng trên Vercel)
VITE_OCR_CCCD_URL=https://<ocr-proxy>.vercel.app/api/ocr
# Tùy chọn, nếu OCR proxy/backend yêu cầu:
# VITE_OCR_CCCD_API_KEY=your-ocr-api-key

# API TTDT nhận điểm (sẽ có Edge Function receive-exam-results)
VITE_TTDT_RECEIVE_GRADES_URL=https://your-ttdt-project.supabase.co/functions/v1/receive-exam-results
# API TTDT kiểm tra CCCD trước khi thi (Edge Function verify-cccd-for-exam)
VITE_TTDT_VERIFY_CCCD_URL=https://your-ttdt-project.supabase.co/functions/v1/verify-cccd-for-exam
VITE_TTDT_API_KEY=your-ttdt-api-key
