# App Thi Online — env
# Copy sang .env và điền giá trị thật

# Supabase (cùng project với TTDT hoặc project riêng)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 1 = COCO-SSD (điện thoại/sách/laptop) + BlazeFace. 0 = chỉ BlazeFace (mặt / nhiều người)
VITE_AI_PROCTORING_ENABLED=0

# API TTDT nhận điểm (Edge Function receive-exam-results)
VITE_TTDT_RECEIVE_GRADES_URL=https://your-ttdt-project.supabase.co/functions/v1/receive-exam-results
# API TTDT kiểm tra CCCD trước khi thi (Edge Function verify-cccd-for-exam)
VITE_TTDT_VERIFY_CCCD_URL=https://your-ttdt-project.supabase.co/functions/v1/verify-cccd-for-exam
VITE_TTDT_API_KEY=your-verify-cccd-api-key

# ─── Serverless proxy env vars (đặt trong Vercel Dashboard, KHÔNG dùng VITE_ prefix) ───
# POTENTIAL_STUDENT_API_KEY=...  (cùng giá trị với chatbot — cho proxy /api/scan-id-card)
# SUPABASE_URL=...               (optional, fallback sang VITE_SUPABASE_URL nếu không set)

# ─── Dev local override (không cần trên Vercel) ───
# Nếu muốn test OCR cục bộ (npm run dev), uncomment và điền thẳng URL Edge Function:
# VITE_TTDT_SCAN_ID_CARD_URL=https://your-project.supabase.co/functions/v1/scan-id-card
# VITE_TTDT_API_KEY dùng để gọi thẳng khi có VITE_TTDT_SCAN_ID_CARD_URL
